[Desktop Entry]
Version=1.0
Type=Application
Name=Tuxpaper Engine
GenericName=Animated Wallpaper Manager
Comment=Manage and apply animated wallpapers
Exec=~/.local/share/Tuxpaper/run.sh
Icon=~/.local/share/Tuxpaper/icons/tuxpaper.svg
Terminal=false
Categories=Utility;Settings;DesktopSettings;
Keywords=wallpaper;background;video;animated;
StartupNotify=true
Path=~/.local/share/Tuxpaper
